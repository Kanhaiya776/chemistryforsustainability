{
    "name": "pantheon-upstreams/drupal-composer-managed",
    "description": "Install Drupal 9 with Composer on Pantheon.",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "path",
            "url": "upstream-configuration"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "require": {
        "pantheon-upstreams/upstream-configuration": "dev-main",
        "composer/installers": "^1.9",
        "drupal/core-composer-scaffold": "^10",
        "drupal/core-recommended": "^10",
        "pantheon-systems/drupal-integrations": "^10",
        "cweagans/composer-patches": "^1.7",
        "drush/drush": "^11 || ^12",
        "drupal/address": "^2.0",
        "drupal/admin_toolbar": "^3.5",
        "drupal/aggregator": "^2.2",
        "drupal/allowed_formats": "^3.0",
        "drupal/antibot": "^2.0",
        "drupal/asset_injector": "^2.21",
        "drupal/webform": "^6.2",
        "drupal/webform_content_creator": "^4.0",
        "drupal/recaptcha_v3": "^2.0",
        "drupal/captcha": "^1.9",
        "drupal/node_view_permissions": "^1.6",
        "drupal/login_emailusername": "^2.1",
        "drupal/devel": "^5.3",
        "drupal/devel_php": "^1.7",
        "drupal/config_readonly": "^1.0",
        "drupal/config_split": "^2.0",
        "drupal/config_track": "^1.0@alpha",
        "drupal/change_pwd_page": "^2.0",
        "drupal/bootstrap_barrio": "^5.5",
        "drupal/webform_user_registration": "^1.0@alpha",
        "drupal/google_translator": "^2.3",
        "drupal/tb_megamenu": "^3.0@alpha",
        "drupal/conditional_fields": "^4.0@alpha",
        "drupal/select2": "^2.0",
        "drupal/better_exposed_filters": "6.0.5",
        "drupal/views_conditional": "^1.10",
        "drupal/views_field_view": "^1.0@beta",
        "drupal/views_remote_data": "^1.0",
        "drupal/clientside_validation": "^4.1",
        "drupal/emulsify_twig": "^5.0",
        "drupal/twig_tweak": "^3.4",
        "drupal/field_group": "^3.6",
        "drupal/field_time": "^1.0@beta",
        "drupal/group": "^3.3",
        "drupal/group_term": "^4.1",
        "drupal/ginvite": "^4.0",
        "drupal/textfield_counter": "^2.5",
        "drupal/paragraphs": "^1.19",
        "drupal/feeds": "^3.2",
        "drupal/config_ignore": "^3.3",
        "drupal/layout_builder_blocks": "^1.1",
        "drupal/layout_builder_modal": "^2.0",
        "drupal/pathauto": "^1.14",
        "drupal/symfony_mailer": "^1.6",
        "drupal/migrate_plus": "^6.0",
        "drupal/migrate_tools": "^6.1",
        "drupal/taxonomy_manager": "^2.0",
        "drupal/structure_sync": "^2.0",
        "drupal/currency": "^3.6",
        "drupal/custom_breadcrumbs": "^1.1",
        "drupal/search_api_solr": "^4.3",
        "drupal/search_api_autocomplete": "^1.11",
        "drupal/facets": "^3.0",
        "drupal/vefl": "^3.2",
        "oomphinc/composer-installers-extender": "^2.0",
        "npm-asset/select2": "^4.0",
        "google/recaptcha": "^1.3",
        "drupal/search_api_pantheon": "^8.3",
        "drupal/subgroup": "^3.0",
        "drupal/grequest": "^3.2",
        "drupal/forum": "^1.0",
        "drupal/block_visibility_groups": "^2.0",
        "drupal/message": "^1.8",
        "drupal/message_notify": "^1.5",
        "drupal/message_digest": "^1.5",
        "drupal/bootstrap_layout_builder": "^2.2",
        "drupal/jsonapi_views": "^1.1",
        "drupal/layout_builder_restrictions": "^2.18",
        "drupal/layout_builder_tabs": "^1.0",
        "drupal/restui": "^1.22",
        "drupal/jquery_ui_datepicker": "^2.1",
        "drupal/jquery_ui_slider": "^2.1",
        "drupal/jquery_ui_touch_punch": "^1.1",
        "drupal/optional_end_date": "^1.4",
        "drupal/single_content_sync": "^1.4",
        "drupal/eu_cookie_compliance": "^1.29",
        "drupal/masquerade": "^2.0",
        "drupal/pager_serializer": "^1.3",
        "drupal/search_api_field_map": "^3.3",
        "drupal/redirect": "^1.12",
        "drupal/webform_address_autocomplete": "^1.0",
        "drupal/simplenews": "^4.1",
        "drupal/rules": "^4.0",
        "doctrine/annotations": "^2.0",
        "drupal/autologout": "^2.0",
        "drupal/simplenews_scheduler": "^4.0@beta",
        "drupal/htmlmail": "^4.0@beta"
    },
    "require-dev": {
        "drupal/core-dev": "^10"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "./web"
            },
            "allowed-packages": ["pantheon-systems/drupal-integrations"],
            "file-mapping": {
                "[project-root]/.editorconfig": false,
                "[project-root]/pantheon.upstream.yml": false,
                "[project-root]/.gitattributes": false
            }
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": [
                "type:drupal-library", 
                "type:bower-asset",
                "type:npm-asset"
            ],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/Commands/contrib/{$name}": ["type:drupal-drush"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"],
            "web/profiles/custom/{$name}": ["type:drupal-custom-profile"],
            "web/themes/custom/{$name}": ["type:drupal-custom-theme"],
            "web/private/scripts/quicksilver/{$name}/": ["type:quicksilver-script"]
        },
        "installer-types": ["bower-asset", "npm-asset"],
        "patches": {
            "drupal/core": {
                "reorder forum hooks": "patches/remove_update_hook.patch"
            },
            "drupal/group_term": {
                "Fix group term View": "https://git.drupalcode.org/project/group_term/-/merge_requests/9.patch"
            },
            "drupal/group": {
                "node add group content no word node": "patches/node-add-no-word-node.patch",
                "Argument #1 ($account) must be of type Drupal\\Core\\Session\\AccountInterface": "patches/group_account_interface_check.patch"
            },
            "drupal/block_visibility_groups": {
                "Required contexts without a value": "https://www.drupal.org/files/issues/2024-08-19/3450675-remove-log.patch"
            },
            "drupal/ginvite": {
                "event subscriber fix": "patches/ginvite-event-subscribe-fix.patch"
            },
            "drupal/vefl": {
                "Fix BEF 6.x constructor compatibility": "https://www.drupal.org/files/issues/2025-06-05/3161777-38.patch",
                "9.1 fixes": "patches/vefl_min_max.patch"
            },
            "drupal/better_exposed_filters": {
                "date format select in BEF:": "patches/bef_patch_datetime.patch",
                "Single on/off option does not work if the filter is not required":  "patches/single_on_off_checkbox_is_always_checked.patch"
            },
            "drupal/search_api_field_map": {
                "decode html entities from tokens": "patches/search-api-map-field-decode-html-entities.patch"
            },
            "drupal/address": {
                "Use Select2 for country dropdown": "patches/address-country-select2.patch"
            }
        },
        "composer-exit-on-patch-failure": true,
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "drupal-lenient": {
            "allowed-list": ["drupal/vefl"]
        },
        "enable-patching": true
    },
    "autoload": {
        "classmap": ["upstream-configuration/scripts/ComposerScripts.php"]
    },
    "scripts": {
        "pre-update-cmd": [
            "DrupalComposerManaged\\ComposerScripts::preUpdate",
            "mkdir -p web/libraries/bootstrap",
            "cp -R vendor/twbs/bootstrap/dist web/libraries/bootstrap"
        ],
        "post-update-cmd": [
            "DrupalComposerManaged\\ComposerScripts::postUpdate",
            "mkdir -p web/libraries/bootstrap",
            "cp -R vendor/twbs/bootstrap/dist web/libraries/bootstrap"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": false,
        "platform": {
            "php": "8.2.26"
        },
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "drupal/core-composer-scaffold": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true,
            "tbachert/spi": true,
            "oomphinc/composer-installers-extender": true
        }
    }
}
