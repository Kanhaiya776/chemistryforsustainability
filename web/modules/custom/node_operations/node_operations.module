/**
 * Implements hook_preprocess_HOOK().
 */
function node_operations_preprocess_menu_local_task(&$variables) {
  $element = $variables['element'];

  if ($element && $element['#link'] && $element['#link']['title'] && $element['#link']['title'] === 'Delete') {
    $link = $variables['link'];

    if ($linkObject = $link['#url']) {
      $request = \Drupal::request();
      $destination = $request->get('redirectPath');
      if ($linkObject instanceof Url && $destination) {
        $linkObject->setOption('query', ['destination' => $destination]);
      }
    }
  }
}
