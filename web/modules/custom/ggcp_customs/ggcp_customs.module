/**
 * Implements hook_FORMID_form_alter().
 */
function ggcp_customs_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if ($form['#id'] == 'views-exposed-form-funding-opportunities-and-innovation-challenges-page-1') {
    $form['type_1']['#options'] = [
      'All' => '- Any -',
      'funding_opportunity' => 'Funding Opportunity',
      'innovation_challenge' => 'Innovation Challenge',
    ];
  }
  elseif ($form['#id'] == 'views-exposed-form-policies-page-1') {
    $form['field_country']['#type'] = 'select';
    unset($form['field_country']['#size']);
    $form['field_country']['#multiple'] = FALSE;
    // $form['field_country']['#options'] = _ggcp_customs_fetch_countries_for_select_list();
  }
  elseif ($form['#id'] == 'views-exposed-form-technology-compendium-page-1') {
    $form['field_country_where_implemented']['#type'] = 'select';
    unset($form['field_country_where_implemented']['#size']);
    $form['field_country_where_implemented']['#multiple'] = FALSE;
    // $form['field_country_where_implemented']['#options'] = _ggcp_customs_fetch_countries_for_select_list();
    $sectors = [
      '' => '- Any -',
      'Academia' => 'Academia',
      'Industry' => 'Industry',
      'Government Sector' => 'Government Sector',
      'Non-Government Organization' => 'Non-Government Organization',
      'Other' => 'Other',
    ];
    $form['referenced_organization_sectors']['#type'] = 'select';
    unset($form['referenced_organization_sectors']['#size']);
    $form['referenced_organization_sectors']['#multiple'] = FALSE;
    $form['referenced_organization_sectors']['#options'] = $sectors;
  }
  elseif ($form['#id'] == 'views-exposed-form-ggcp-only-events-page-2') {
    $form['field_event_date_wrapper']['field_event_date_wrapper']['field_event_date']['min']['#title'] = 'Begin Range';
    $form['field_event_date_wrapper']['field_event_date_wrapper']['field_event_date']['max']['#title'] = 'End Range';
  }
  elseif ($form['#id'] == 'views-exposed-form-collaboration-opportunities-page-1') {
    $form['field_start_date_1_wrapper']['field_start_date_1_wrapper']['field_start_date_1']['min']['#title'] = 'Earliest starting date';
    $form['field_start_date_1_wrapper']['field_start_date_1_wrapper']['field_start_date_1']['max']['#title'] = 'Latest starting date';
  }
}

