        'acs_address' => NULL,
        'beyongbenign_address' => NULL,
        'ggcp_address' => NULL,
      ],
    ],
    'search_bar_block' => [
      'variables' => [
        'extra_class' => NULL,
        'display_background_image' => NULL,
      ],
    ],
    'header_user_block' => [
      'variables' => [
        'redirectUrl' => NULL,
      ],
    ],
    'access_denied' => [
      'variables' => [
        'destination' => NULL,
        'redirectPath' => NULL,
      ],
    ],
    'cards_block' => [
      'variables' => [],
    ],
    'banner_wrapper' => [
      'variables' => [
        'powered_by_block' => NULL,
        'search_block' => NULL,
        'cards_block' => NULL,
      ],
    ],
    'visit_our_sister_sites_block' => [
      'variables' => [],
    ],
    'explore_more_networks' => [
      'variables' => [],
    ],
