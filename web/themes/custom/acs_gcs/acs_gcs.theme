<?php

/**
 * @file
 * Functions to support theming in the SASS Starterkit subtheme.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\node\NodeInterface;
use Drupal\user\Entity\User;
use Drupal\views\ViewExecutable;
use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Url;
use Symfony\Component\HttpFoundation\RedirectResponse;
use Drupal\node\Entity\Node;
use Drupal\user\UserInterface;
use Drupal\address\Repository\SubdivisionRepository;

/**
 * Implements hook_form_system_theme_settings_alter() for settings form.
 *
 * Replace Barrio setting options with subtheme ones.
 *
 * Example on how to alter theme settings form
 */
function acs_gcs_form_system_theme_settings_alter(&$form, FormStateInterface $form_state) {
  $form['components']['navbar']['bootstrap_barrio_navbar_top_background']['#options'] = [
    'bg-primary' => t('Primary'),
    'bg-secondary' => t('Secondary'),
    'bg-light' => t('Light'),
    'bg-dark' => t('Dark'),
    'bg-white' => t('White'),
    'bg-transparent' => t('Transparent'),
  ];
  $form['components']['navbar']['bootstrap_barrio_navbar_background']['#options'] = [
    'bg-primary' => t('Primary'),
    'bg-secondary' => t('Secondary'),
    'bg-light' => t('Light'),
    'bg-dark' => t('Dark'),
    'bg-white' => t('White'),
    'bg-transparent' => t('Transparent'),
  ];

  $form['fonts']['fonts']['bootstrap_barrio_google_fonts']['#options']['open_sans_custom'] = 'Open Sans Skvare';
}

/**
 * Implements hook_views_view_fields().
 */
function acs_gcs_preprocess_views_view_fields(&$variables) {
  /** @var \Drupal\views\ViewExecutable $view */
  $view = $variables['view'];

  if ($view->id() === 'recent_activity' && $view->current_display === 'block_1') {
    $title = $variables['fields']['title'];
  }

  if ($view->id() === 'user_profile' && $view->current_display === 'all_user_details') {
    $routeMatch = \Drupal::routeMatch();

    $routeName = $routeMatch->getRouteName();

    if ($routeName === "entity.user.canonical") {
      $user = $routeMatch->getParameter('user');
      if ($user instanceof UserInterface) {
        $accountData = \Drupal::service('user.data')->get('contact', $user->id(), 'enabled');
        $allow_dm = $user->get('field_allow_direct_messaging')->value;
        // $showContact = $accountData ?? FALSE;
        $showContact = $allow_dm ?? FALSE;
        $userId = $user->id();
        $currentUser = \Drupal::currentUser();
        $url = Url::fromRoute('entity.user.contact_form', ['user' => $userId]);
        $variables['fields']['contactFormUrl'] = $url->toString();
        $variables['fields']['showContact'] = $allow_dm == 1  &&  $showContact;
        $variables['fields']['ownProfile'] = $userId === $currentUser->id();

        if ($userId !== $currentUser->id()) {
          unset($variables['fields']['nothing']);
        }

      }
    }
  }
}

/**
 * Implements hook_preprocess_page().
 */
function acs_gcs_preprocess_page(&$variables) {
  $fonts = theme_get_setting('bootstrap_barrio_google_fonts');
  if ($fonts === 'open_sans_custom') {
    $variables['#attached']['library'][] = 'acs_gcs/open_sans_custom';
  }

  if (\Drupal::service('path.matcher')->isFrontPage()) {
    $variables['#attached']['html_head'][] = [
        [
          '#tag' => 'title',
          '#value' => "Green Chemistry For Sustainability",
        ], 'custom_frontpage_title',
    ];
  }

  $request = \Drupal::request();
  $path_info = $request->getPathInfo();

  if ($path_info === '/form/update-organization-form') {
    $url = Url::fromUri('internal:/non-existent-path')->toString();
    $response = new RedirectResponse($url, 302);
    $response->send();
  }
}

/**
 * Implements hook_theme_suggestions_views_view_alter().
 */
function acs_gcs_theme_suggestions_views_view_alter(array &$suggestions, array $variables) {
  $view = $variables['view'];
  $suggestions[] = 'views_view__' . $view->id();
  $suggestions[] = 'views_view__' . $view->id() . '__' . $view->current_display;
}

/**
 * Implements hook_theme_suggestions_views_view_unformatted_alter().
 */
function acs_gcs_theme_suggestions_views_view_unformatted_alter(array &$suggestions, array $variables) {
  $view = $variables['view'];
  if ($view instanceof ViewExecutable && $view_id = $view->id() && $display_id = $view->current_display) {
    $suggestions[] = 'views_view_unformatted__' . $view_id . '__' . $display_id;
  }
}

/**
 * Implements hook_theme_suggestions_form_alter().
 */
function acs_gcs_theme_suggestions_form_alter(array &$suggestions, array $variables) {
  $routeMatch = \Drupal::routeMatch();
  $routeName = $routeMatch->getRouteName();
  if ($routeName === 'entity.node.add_form' || $routeName === 'entity.node.edit_form' ||
  $routeName === 'node.add' || $routeName === 'node.edit') {
    $node = $routeMatch->getParameter('node');

    $type = $node instanceof NodeInterface ? $node->getType() : NULL;

    if ($type) {
      $suggestions[] = 'form__custom_node_template__' . $type;
    }
    $suggestions[] = 'form__custom_node_template';
  }
}

/**
 * Implements hook_theme_suggestions_views_view_fields_alter().
 */
function acs_gcs_theme_suggestions_views_view_fields_alter(array &$suggestions, array $variables) {
  $view = $variables['view'];
  if ($view instanceof ViewExecutable && $view_id = $view->id() && $current_display = $view->current_display) {
    $suggestions[] = 'views_view_fields__' . $view_id . '__' . $current_display;
  }
}

/**
 * Implements hook_preprocess_HOOK().
 */
function acs_gcs_preprocess_paragraph__amounts__sign_and_amount(&$variables) {
  $amount = '';
  if (!empty($variables['content']['field_amount'][0]['#markup'])) {
    $amount = $variables['content']['field_amount'][0]['#markup'];
  }
  if (!empty($variables['content']['field_currency'][0]['#entity'])) {
    $currency = $variables['content']['field_currency'][0]['#entity'];
    if (method_exists($currency, 'getSign')) {
      $sign = $currency->getSign();
      if (!empty($amount)) {
        $variables['currency_and_amount'] = $sign . $amount;
      }
    }
  }

}

