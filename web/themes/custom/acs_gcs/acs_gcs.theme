/**
 * Implements hook_preprocess_views_view_field().
 */
function acs_gcs_preprocess_views_view_field(&$variables) {
  // Event date time & timezone formating.
  if ($variables['field']->field == 'field_event_date_s_2') {
    try {
      $entity = $variables['row']->_entity;
      $start_date = $entity->field_event_date_s_2->value;
      $end_date = $entity->field_event_date_s_2->end_value;
      $start_time = '';
      $end_time = '';
      $timezone = '';
      if (!empty($entity->field_event_time)) {
        $start_time = $entity->field_event_time->getValue()[0]['from'];
        $end_time = $entity->field_event_time->getValue()[0]['to'];
      }

      if (!empty($entity->field_timezone->value)) {
        $timezone = $entity->field_timezone->value;
      }

      $sdate = new DrupalDateTime($start_date);
      $edate = new DrupalDateTime($end_date);

      if (!empty($start_time) && !empty($end_time)) {
        $formatter = \Drupal::service('date.formatter');
        $formatted_start = \Drupal::service('date.formatter')->format($sdate->getTimestamp(), 'custom', 'F j, Y');

        $output = "<b>Event Dates:</b> $formatted_start, " . $formatter->format(strtotime($start_time), 'custom', 'g:i a');
        if ($end_date && $end_time) {
          $formatted_end = \Drupal::service('date.formatter')->format($edate->getTimestamp(), 'custom', 'F j, Y');
          $output .= " - $formatted_end, " . $formatter->format(strtotime($end_time), 'custom', 'g:i a') . " " . $timezone;
        }

        $variables['output'] = [
          '#markup' => $output,
          '#cache' => [
            'contexts' => ['timezone'],
            'tags' => ['node:' . $entity->id()],
          ],
        ];
      }
      else {
        $formatted_start = \Drupal::service('date.formatter')->format($sdate->getTimestamp(), 'custom', 'F j, Y');
        $formatted_end = \Drupal::service('date.formatter')->format($edate->getTimestamp(), 'custom', 'F j, Y');
        $output = "<b>Event Dates:</b> $formatted_start" . " - " . $formatted_end . " " . $timezone;
        $variables['output'] = [
          '#markup' => $output,
          '#cache' => [
            'contexts' => ['timezone'],
            'tags' => ['node:' . $entity->id()],
          ],
        ];
      }
    }
    catch (\Exception $e) {
      $variables['output'] = [
        '#markup' => t('Event dates are not available'),
      ];
    }
  }
}

/**
 * Check if the user is creator and allow the organization to be edit.
 */
function acs_gcs_check_organization_relations_allow_update($civiuserId, $contact_id) {
  $allowOrganizationEdit = FALSE;

  if (!empty($civiuserId) && !empty($contact_id)) {
    $result = civicrm_api3('Relationship', 'get', [
      'sequential' => 1,
      'contact_id_a' => $civiuserId,
      'contact_id_b' => $contact_id,
    ]);

    $allowededRelations = ["13"];
    if (count($result["values"]) > 0) {
      foreach ($result["values"] as $res) {
        if (in_array($res["relationship_type_id"], $allowededRelations)) {
          $allowOrganizationEdit = TRUE;
        }
      }
    }
  }

  return $allowOrganizationEdit;
}

/**
 * Implements hook_form_alter().
 */
function acs_gcs_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if ($form_id == "node_professional_development_form" || $form_id == "node_professional_development_edit_form") {
    $form['#after_build'][] = 'acs_gcs_add_paragraph';
    if (isset($form['field_target_audience'])) {
      $options = [];
      $terms = \Drupal::entityTypeManager()
        ->getStorage('taxonomy_term')
        ->loadByProperties(['vid' => 'target_audience', 'status' => 1]);

      foreach ($terms as $term) {
        $options[$term->id()] = $term->label();
      }
      if (isset($form['field_target_audience']['widget']['#options'])) {
        $form['field_target_audience']['widget']['#options'] = $options;
      }
    }
    // Target node forms (both create and edit).
    if (str_starts_with($form_id, 'node_') && str_ends_with($form_id, '_form')) {
      // Check if user has permission to administer nodes.
      $account = \Drupal::currentUser();
      if (!$account->hasPermission('administer nodes')) {
        // Hide the revision vertical tab.
        if (isset($form['revision_information'])) {
          $form['revision_information']['#access'] = FALSE;
        }
        $form['#prefix'] = '<div class="container mt-4">';
        $form['#suffix'] = '</div>';
      }
    }
    $form['field_length_time_of_training']['#access'] = FALSE;
    $form['field_location_name']['#states'] = [
      'visible' => [
        [
          ':input[name="field_training_format"]' => ['value' => '544'],
        ],
        'or',
        [
          ':input[name="field_training_format"]' => ['value' => '545'],
        ],
      ],
    ];

    $form['field_location_address']['#states'] = [
      'visible' => [
        [
          ':input[name="field_training_format"]' => ['value' => '544'],
        ],
        'or',
        [
          ':input[name="field_training_format"]' => ['value' => '545'],
        ],
      ],
    ];

    $form['field_location_country']['#states'] = [
      'visible' => [
        [
          ':input[name="field_training_format"]' => ['value' => '544'],
        ],
        'or',
        [
          ':input[name="field_training_format"]' => ['value' => '545'],
        ],
      ],
    ];
  }

  // Add helper text for password.
  if ($form_id == "user_login_form") {
    $form['pass']['#description'] = t('Enter your password.');
  }
}

/**
 * Get similar nodes based for professional devleopment.
 */
function acs_gcs_get_similar_nodes(Node $node, $limit = 3) {
  $similar_nodes = [];

  $query = \Drupal::entityQuery('node')
    ->accessCheck(TRUE)
    ->condition('status', 1)
    ->condition('type', $node->bundle())
    ->condition('nid', $node->id(), '!=')
    ->range(0, $limit)
    ->sort('created', 'DESC');

  $nids = $query->execute();

  if (!empty($nids)) {
    $nodes = Node::loadMultiple($nids);
    $similar_nodes = array_values($nodes);
  }

  return $similar_nodes;
}

/**
 * Implements hook_preprocess_HOOK() for HTML document.
 */
function acs_gcs_preprocess_node(&$variables) {
  $node = $variables['node'];
  // Only for professional development content type.
  if ($node->bundle() === 'professional_development') {
    $similar_nodes = acs_gcs_get_similar_nodes($node);
    $countries = \Drupal::service('country_manager')->getList();
    foreach ($similar_nodes as $key => $similar_node) {

      // Get raw DB datetime value (string)
      $raw = $similar_node->get('field_time_of_training')->value;
      $raw1 = $similar_node->get('field_time_of_training')->end_value;
      $rawRegistrationEnd = $similar_node->get('field_registrations_date_time')->end_value;

      $country_name = '';
      if (
        $similar_node->hasField('field_location_country') &&
        !$similar_node->get('field_location_country')->isEmpty()
      ) {
        $code = $similar_node->get('field_location_country')->value;
        $country_name = $countries[$code] ?? $code;
      }

      if ($raw) {
        // Create DrupalDateTime assuming DB value is UTC.
        $datetime = new DrupalDateTime($raw, new \DateTimeZone('UTC'));

        // Convert to CST (America/Chicago)
        $datetime->setTimezone(new \DateTimeZone('America/Chicago'));

        // Add formatted string to node object for Twig.
        $similar_node->converted_training_start_time = $datetime->format('F j, Y');
      }

      if ($raw1) {
        $datetime1 = new DrupalDateTime($raw1, new \DateTimeZone('UTC'));
        $datetime1->setTimezone(new \DateTimeZone('America/Chicago'));
        $similar_node->converted_training_end_time = $datetime1->format('F j, Y');
      }

      if ($rawRegistrationEnd) {
        $datetime2 = new DrupalDateTime($rawRegistrationEnd, new \DateTimeZone('UTC'));
        $datetime2->setTimezone(new \DateTimeZone('America/Chicago'));
        $similar_node->converted_registration_end_time = $datetime2->format('F j, Y');
      }

      $similar_node->location_country_name = $country_name;
    }
    $variables['similar_nodes'] = $similar_nodes;
  }
  if ($variables['node']->bundle() === 'organization') {

    $address = $variables['node']->get('field_state')->first();
    if ($address) {
      $country_code = $address->getCountryCode();
      $state = $address->getAdministrativeArea();
      $city = $address->getLocality();

      // Get country name.
      $country_manager = \Drupal::service('country_manager');
      $countries = $country_manager->getList();
      $country_name = $countries[$country_code] ?? $country_code;

      $variables['organization_location'] = [
        'city' => $city,
        'state' => $state,
        'country' => $country_name,
      ];
    }
  }
  if ($node->bundle() === 'organization') {
    $address = $variables['node']->get('field_state')->first();

    if ($address) {
      $country_code = $address->getCountryCode();
      $state_code = $address->getAdministrativeArea();
      $city = $address->getLocality();

      // Country label.
      $country_manager = \Drupal::service('country_manager');
      $countries = $country_manager->getList();
      $country_name = $countries[$country_code] ?? $country_code;

      // State / province label (Address module).
      $state_name = $state_code;
      if ($country_code && $state_code) {
        /** @var \Drupal\address\Repository\SubdivisionRepository $subdivision_repository */
        $subdivision_repository = \Drupal::service('address.subdivision_repository');

        $subdivisions = $subdivision_repository->getList([$country_code]);

        if (!empty($subdivisions[$state_code])) {
          $state_name = $subdivisions[$state_code];
        }
      }

      $variables['organization_location'] = [
        'city' => $city,
        'state' => $state_name,
        'country' => $country_name,
      ];
    }
    $uid = 0;

    // 1. Prefer explicit creator field.
    if (
      $node->hasField('field_creator_user') &&
      !$node->get('field_creator_user')->isEmpty()
    ) {
      $uid = (int) $node->get('field_creator_user')->target_id;
    }

    // 2. Fallback for legacy nodes.
    if ($uid <= 0) {
      $uid = (int) $node->getOwnerId();
    }

    /** @var \Drupal\custom_organization\Service\OrganizationCreatorService $creatorService */
    $creatorService = \Drupal::service('custom_organization.organization_creator');

    $creator = $creatorService->getCreatorByUid($uid);

    if ($creator) {
      $variables['organization_creator'] = $creator;
    }
    /** @var \Drupal\custom_organization\Service\OrganizationPeopleService $peopleService */
    $peopleService = \Drupal::service('custom_organization.organization_people');

    $related_people = $peopleService->getRelatedPeople($node);

    // Optional: exclude creator from related list.
    if (!empty($uid)) {
      $related_people = array_values(array_filter(
        $related_people,
        fn($person) => (int) $person['uid'] !== $uid
      ));
    }

    // $current_page = (int) \Drupal::request()->query->get('page', 0);

    // $limit = ($current_page === 0) ? 11 : 12;

    // $total = count($related_people);

    // $pager_manager = \Drupal::service('pager.manager');
    // $pager_manager->createPager($total, $limit);

    // $variables['related_people'] = array_slice(
    //   $related_people,
    //   $current_page * $limit,
    //   $limit
    // );

    $current_page = (int) \Drupal::request()->query->get('page', 0);

    $first_page_limit = 11;
    $other_pages_limit = 12;

    $total = count($related_people);

    $pager_manager = \Drupal::service('pager.manager');

    $pager_manager->createPager($total, $other_pages_limit);

    // Calculate offset correctly.
    if ($current_page === 0) {
      $offset = 0;
      $limit = $first_page_limit;
    }
    else {
      $offset = $first_page_limit + (($current_page - 1) * $other_pages_limit);
      $limit = $other_pages_limit;
    }

    $variables['related_people'] = array_slice($related_people, $offset, $limit);

    // Hide creator after page 1.
    if ($current_page > 0) {
      unset($variables['organization_creator']);
    }

    $variables['pager'] = [
      '#type' => 'pager',
    ];

  }
  if ($node->hasField('field_location_country') && !$node->get('field_location_country')->isEmpty()) {
    $code = $node->get('field_location_country')->value;
    $countries = \Drupal::service('country_manager')->getList();
    $variables['location_country_name'] = $countries[$code] ?? $code;
  }
}

/**
 * Custom function to add a <p> tag at the end of the form.
 */
function acs_gcs_add_paragraph(array $form, FormStateInterface $form_state) {
  $form['field_pf_accept_terms']['#weight'] = 9999;

  return $form;
}
