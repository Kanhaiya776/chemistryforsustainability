{% import '@acs_gcs/macros/date_range_macros.html.twig' as macros %}
{% if node.field_attachments.0 %}
    {% set file = node.field_attachments.0 %}
    {% set file_uri = file.entity.uri.value %}
    {% set file_url = file_url(file_uri) %}
    {% set filename = file.entity.filename.value|split('.')[0]|upper %}
    {% set file_size = (file.entity.filesize.value / 1024) | number_format(2) %}
    {% set mime_type = file.entity.filemime.value %}

    {% if mime_type starts with 'image/' %}
        {% set icon = 'bi-file-earmark-image' %}
				{% set mime_name = "Image" %}
    {% elseif mime_type == 'application/pdf' %}
        {% set icon = 'bi-file-earmark-pdf' %}
				{% set mime_name = "PDF" %}
    {% elseif mime_type in ['application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'] %}
        {% set icon = 'bi-file-earmark-word' %}
				{% set mime_name = "Word" %}
    {% elseif mime_type in ['application/vnd.ms-powerpoint', 'application/vnd.openxmlformats-officedocument.presentationml.presentation'] %}
        {% set icon = 'bi-file-earmark-ppt' %}
				{% set mime_name = "PPT" %}
    {% elseif mime_type in ['application/vnd.ms-excel', 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'] %}
        {% set icon = 'bi-file-earmark-excel' %}
				{% set mime_name = "XLS" %}
    {% elseif mime_type == 'text/plain' %}
        {% set icon = 'bi-file-earmark-text' %}
				{% set mime_name = "Text" %}
    {% endif %}
{% endif %}
{% set training_timezone_parts = node.field_professional_dev_timezone.value is not empty ? node.field_professional_dev_timezone.value|split('|') : "" %}
{% set registration_timezone_parts = node.field_registrations_time_zone.value is not empty ? node.field_registrations_time_zone.value|split('|') %}

<!-- Header Section -->
<div class="header-section">
	<div class="container">
    	<div class="row">
			<div class="col-md-12">
				<h1 class="header-title">{{ node.label|raw }}</h1>
			</div>
		</div>
    </div>
</div>
<!-- Info Section -->
<div class="container">
	<div class="row pt-2 pb-2">
		<div class="col-lg-4 col-md-12 col-sm-12">
			<div class="info-section-bg info-section">
			{% if node.field_time_of_training.value is not empty %}
			<div><strong>Date/Time:</strong><br>
				<div class="training-date-time-wrapper">
				{{ macros.training_date_range(content.field_time_of_training['#items'].0) }}
				{% if training_timezone_parts is not empty %}
					{{ training_timezone_parts[1] }} ({{ training_timezone_parts[0] }})<br> 
				{% endif %}
				</div>
			</div>
			<p></p>
			{% endif %}
			{% if node.field_location_country.value is not empty %}
			<p><strong>Location:</strong><br>
				{% if node.field_location_name.value is not empty %}
						{{ node.field_location_name.value }},
				{% endif %}
				{% if node.field_location_address.value is not empty %}
						{{ node.field_location_address.value }},
				{% endif %}
				{% if node.field_location_country.value is not empty %}
						{{location_country_name}}
				{% endif %}
			</p>
			{% endif %}
			<p><strong>Training Format:</strong><br>{{node.field_training_format.entity.label}}</p>
			<p><strong>Training Level:</strong><br>
				{% for item in node.field_level_of_training %}
          			{{ item.entity.label }}{% if not loop.last %}, {% endif %}
        		{% endfor %}
			</p>
			<p><strong>Organization:</strong><br><a href="/organization/{{ node.field_organization.target_id	}}" class="text-orange">{{ node.field_organization.entity.label}}</a></p>
			{% if node.field_target_audience is not empty %}
			<p><strong>Who should attend?</strong><br>
				{% for item in node.field_target_audience %}
						{{ item.entity.label }}{% if not loop.last %}, {% endif %}
				{% endfor %}
			</p>
			{% endif %}
			</div>
		</div>
		<div class="col-lg-8 col-md-12 col-sm-12">
			<!-- Hero Image Section -->
			{% if node.field_image.entity.uri.value %}
				<img src="{{ node.field_image.entity.uri.value | file_url }}" alt="{{ node.field_image.alt }}" class="opportunity-image" >
			{% else %}
				<img src="{{ app.request.basePath }}/{{ base_path ~ directory ~ '/images/background/professional-developemnt-placeholder.webp' }}" alt="Professional Development Image" class="opportunity-image" />
			{% endif %}
		</div>
	</div>
</div>
<!-- Main Content -->
<div class="container">
    <div class="row">
        <div class="col-12">
            <div class="opportunity-details">
                <!-- Description Section -->
                <h2 class="section-title">Description</h2>
                <p class="description-text">{{ node.body.value|raw }}</p>
                
                <!-- Prerequisites Section -->
                {% if node.field_prerequisites.value is not empty %}
                <h2 class="section-title">Prerequisites</h2>
                <p class="description-text">{{ node.field_prerequisites.value|raw }} </p>
                {% endif %}

                <!-- Related Safer Alternative Section -->
                {% if node.field_related_technology_compend is not empty %}
                <h2 class="section-title">Related Safer Alternative</h2>
                <p class="description-text">{{ node.field_related_technology_compend.entity.label }}</p>
                {% endif %}

                <!-- Date(s) and Time(s) Section -->
                {% if node.field_time_of_training.value is not empty %}
                <h2 class="section-title">Date(s) and Time(s)</h2>
                <div class="datetime addtl-info-text">
                    {{ macros.training_date_range(content.field_time_of_training['#items'].0) }} &nbsp;
                    {% if training_timezone_parts is not empty%}
                        {{ training_timezone_parts[1] }} ({{ training_timezone_parts[0] }})<br> 
                    {% endif %}
                </div>
                {% endif %}

                {% if node.field_length_time_of_training is not empty %}
                    <h2 class="section-title">Duration (time) of training</h2>
                    <p class="addtl-info-text">{{ node.field_length_time_of_training.value }}</p>
                {% endif %}

                <!-- Location Section -->
                {% if node.field_location_country.value is not empty %}
                <h2 class="section-title">Location</h2>
                <p class="addtl-info-text">
                    {% if node.field_location_name.value is not empty %}
                        {{ node.field_location_name.value }},
                    {% endif %}
                    {% if node.field_location_address.value is not empty %}
                        {{ node.field_location_address.value }},
                    {% endif %}
                    {% if node.field_location_country.value is not empty %}
                        {{location_country_name}}
                    {% endif %}
                </p>
                {% endif %}

                <!-- Attachments Section -->
                {% if node.field_attachments is not empty %}
                <h2 class="section-title">Attachments</h2>
                <div class="attachment-item row">
					<div class="attachment-icon col-lg-1 col-md-2 col-sm-2 col-xs-2">
                    	<i class="bi {{icon}}"></i>
					</div>
                    <div class="attachment-info col-lg-9 col-md-7 col-sm-10 col-xs-10">
                        <div class="attachment-name">
							{% if node.field_attachment_name is not empty %}
								{{ node.field_attachment_name.value }}
							{% else %}
								{{  filename }}
							{% endif %}
						</div>
                <div class="attachment-details">{{ mime_name }}, {{ file_size }} KB<br/> {{ node.field_attachments.value.0.description }}</div>
                    </div>
                    <div class="col-lg-2 col-md-3 col-sm-12 col-xs-12 card-btn">	
						<a href="{{ file_url }}" target="_blank" class="download-btn" download >
							<img src="{{ app.request.basePath }}/{{ base_path ~ directory ~ '/images/icons/download.png' }}" />   Download
						</a>
					</div>
                </div>
                {% endif %}

                <!-- Related Fields of Interest -->
                {% if node.field_field_of_interest is not empty %}
                <h2 class="section-title">Related Fields of Interest</h2>
                <p class="related-field-int">
                    {% for item in node.field_field_of_interest %}
                      <a href="{{ url('entity.taxonomy_term.canonical', {'taxonomy_term': item.entity.id})  }}" class="text-orange">{{ item.entity.label }}</a>{% if node.field_specify_other_interest4.value is not empty %}, {% endif %}
                    {% endfor %}
                {% endif %}

                {% if node.field_specify_other_interest4 is not empty %}
									<a href="#" class="text-orange">{{ node.field_specify_other_interest4.value }}</a>
                {% endif %}
                </p>

                <!-- For Details Visit -->
                {% if node.field_link is not empty %}
                    <p class="addtl-info-text"><strong>For Details Visit:</strong> <a class="text-orange" href="{{ node.field_link.uri }}" target="_blank">{{ node.field_link.uri }}</a></p>
                {% endif %}

                <!-- Registration Information -->
                {% if node.field_registrations_date_time is not empty %}
                    <p class="addtl-info-text"><strong>Registration Opens:</strong> {{ content.field_registrations_date_time['#items'].0.start_date|date('F j, Y') }}<br>
											{% if content.field_registrations_date_time['#items'].0.end_date is not empty %}	
											<strong>Registration Ends:</strong> {{ content.field_registrations_date_time['#items'].0.end_date|date('F j, Y') }}
											{% endif %}
										</p>
                {% endif %}


                <!-- Register Button -->
                <a href="{{node.field_training_registration_link.uri}}" target="_blank" class="btn btn-submit-custom">Register</a>
            </div>
        </div>
    </div>
</div>
