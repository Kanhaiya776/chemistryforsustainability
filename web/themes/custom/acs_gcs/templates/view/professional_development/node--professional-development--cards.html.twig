{% import '@acs_gcs/macros/date_range_macros.html.twig' as macros %}
<div class="col-lg-4 col-md-6 mb-4">
    <div class="opportunity-card">
        <div class="status-badge">
            {{node.field_training_format.entity.label}}
        </div>
        <a href="{{ url }}">
            {% if node.field_image.entity.uri.value %}
                <img src="{{ node.field_image.entity.uri.value | image_style('professional_development_card_thumbnail') }}" alt="{{ node.field_image.alt }}" class="card-image">
            {% else %}
                <img src="{{ app.request.basePath }}/{{ base_path ~ directory ~ '/images/background/professional-developemnt-placeholder.webp' }}" alt="Professional Development Image" class="card-image" />
            {% endif %}
        </a>
        <div class="card-content">
            <a href="{{ url }}" class="card-title">
                {{ node.label|raw }}
            </a>
            <p class="card-description">
                {{ node.body.value|striptags|slice(0, 150) ~ '...' }}
            </p>
            <div class="card-details">
                <div class="row">
                    <div class="card-icon col-1">
                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
                            width="17.846" height="15.863" viewBox="0 0 17.846 15.863">
                            <defs>
                                <clipPath id="clip-path">
                                    <rect id="Rectangle_1243" data-name="Rectangle 1243" width="17.846" height="15.863"
                                        transform="translate(0 0)" fill="none" />
                                </clipPath>
                            </defs>
                            <g id="Group_376" data-name="Group 376" transform="translate(0 0)">
                                <g id="Group_375" data-name="Group 375" clip-path="url(#clip-path)">
                                    <path id="Path_720" data-name="Path 720"
                                        d="M11.9,0A2,2,0,0,1,13.88,1.983V5.949h1.983a2,2,0,0,1,1.983,1.983v5.949a2,2,0,0,1-1.983,1.982H1.983A2,2,0,0,1,0,13.881V4.957A1.963,1.963,0,0,1,1.487,3.036V.744a.744.744,0,1,1,1.487,0v2.23H4.957V.744a.744.744,0,1,1,1.487,0v2.23H7.932V1.983A2,2,0,0,1,9.915,0ZM2.478,5.949a.489.489,0,0,0-.495.495v.992a.489.489,0,0,0,.495.5H3.47a.489.489,0,0,0,.495-.5V6.444a.489.489,0,0,0-.495-.495ZM3.47,8.923H2.478a.489.489,0,0,0-.495.5v.992a.489.489,0,0,0,.495.495H3.47a.489.489,0,0,0,.495-.495V9.419a.489.489,0,0,0-.495-.5M6.444,5.949a.489.489,0,0,0-.5.495v.992a.49.49,0,0,0,.5.5h.992a.49.49,0,0,0,.5-.5V6.444a.49.49,0,0,0-.5-.495Zm.992,2.974H6.444a.49.49,0,0,0-.5.5v.992a.489.489,0,0,0,.5.495h.992a.49.49,0,0,0,.5-.495V9.419a.49.49,0,0,0-.5-.5M11.4,2.974H10.41a.489.489,0,0,0-.495.5v.992a.489.489,0,0,0,.495.495H11.4a.489.489,0,0,0,.495-.495V3.47a.489.489,0,0,0-.495-.5M10.41,5.949a.489.489,0,0,0-.495.495v.992a.489.489,0,0,0,.495.5H11.4a.489.489,0,0,0,.495-.5V6.444a.489.489,0,0,0-.495-.495ZM11.4,8.923H10.41a.489.489,0,0,0-.495.5v.992a.489.489,0,0,0,.495.495H11.4a.489.489,0,0,0,.495-.495V9.419a.489.489,0,0,0-.495-.5m2.974,0a.49.49,0,0,0-.5.5v.992a.489.489,0,0,0,.5.495h.991a.489.489,0,0,0,.5-.495V9.419a.49.49,0,0,0-.5-.5Z"
                                        fill="#033c6b" />
                                </g>
                            </g>
                        </svg>
                    </div>
                    <div class="col-11">
                        <strong>
                            Organization:
                        </strong>
                        <br>
                        {{ content.field_organization}}
                    </div>
                </div>
                {% if node.field_time_of_training.value is not empty %}
                <div class="row">
                    <div class="card-icon col-1">
                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
                            width="15.423" height="16.524" viewBox="0 0 15.423 16.524">
                            <defs>
                                <clipPath id="clip-path">
                                    <rect id="Rectangle_1243" data-name="Rectangle 1243" width="15.423" height="16.524"
                                        transform="translate(0 0)" fill="none" />
                                </clipPath>
                            </defs>
                            <g id="Group_376" data-name="Group 376" transform="translate(0 0)">
                                <g id="Group_375" data-name="Group 375" clip-path="url(#clip-path)">
                                    <path id="Path_720" data-name="Path 720"
                                        d="M4.406,0a1.088,1.088,0,0,1,1.1,1.1V2.2H9.914V1.1a1.1,1.1,0,0,1,2.2,0V2.2h1.1a2.218,2.218,0,0,1,2.2,2.2V14.32a2.219,2.219,0,0,1-2.2,2.2H2.2A2.219,2.219,0,0,1,0,14.32V4.406A2.218,2.218,0,0,1,2.2,2.2H3.3V1.1A1.088,1.088,0,0,1,4.406,0M2.2,8.262v1.1a.544.544,0,0,0,.551.551h1.1a.544.544,0,0,0,.551-.551v-1.1a.544.544,0,0,0-.551-.551h-1.1a.544.544,0,0,0-.551.551m0,4.406v1.1a.544.544,0,0,0,.551.55h1.1a.544.544,0,0,0,.551-.55v-1.1a.544.544,0,0,0-.551-.551h-1.1a.544.544,0,0,0-.551.551M6.609,8.262v1.1a.544.544,0,0,0,.551.551h1.1a.544.544,0,0,0,.551-.551v-1.1a.544.544,0,0,0-.551-.551H7.16a.544.544,0,0,0-.551.551m.551,3.855a.544.544,0,0,0-.551.551v1.1a.544.544,0,0,0,.551.55h1.1a.544.544,0,0,0,.551-.55v-1.1a.544.544,0,0,0-.551-.551Zm4.407-4.406a.544.544,0,0,0-.551.551v1.1a.544.544,0,0,0,.551.551h1.1a.544.544,0,0,0,.551-.551v-1.1a.544.544,0,0,0-.551-.551Zm-.551,4.957v1.1a.544.544,0,0,0,.551.55h1.1a.544.544,0,0,0,.551-.55v-1.1a.544.544,0,0,0-.551-.551h-1.1a.544.544,0,0,0-.551.551"
                                        fill="#033c6b" />
                                </g>
                            </g>
                        </svg>
                    </div>
                    <div class="col-11">
                        <strong>
                            Training Date(s):
                        </strong>
                        {{ macros.training_date_range(content.field_time_of_training['#items'].0, false) }}
                    </div>
                </div>
                {% endif %}
                {% if node.field_location_country.value is not empty %}
                <div class="row">
                    <div class="card-icon col-1">
                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="13.22"
                            height="17.72" viewBox="0 0 13.22 17.72">
                            <defs>
                                <clipPath id="clip-path">
                                    <rect id="Rectangle_1243" data-name="Rectangle 1243" width="13.22" height="17.72"
                                        transform="translate(0 0)" fill="none" />
                                </clipPath>
                            </defs>
                            <g id="Group_376" data-name="Group 376" transform="translate(0 0)">
                                <g id="Group_375" data-name="Group 375" clip-path="url(#clip-path)">
                                    <path id="Path_720" data-name="Path 720"
                                        d="M0,6.507A6.546,6.546,0,0,1,6.61,0a6.546,6.546,0,0,1,6.61,6.507c0,4.1-4.131,9.019-5.853,10.878a1.022,1.022,0,0,1-1.514,0C4.131,15.526,0,10.6,0,6.507M6.61,8.813a2.2,2.2,0,1,0-2.2-2.2,2.219,2.219,0,0,0,2.2,2.2"
                                        fill="#033c6b" />
                                </g>
                            </g>
                        </svg>
                    </div>
                    <div class="col-11">
                        <strong>
                            Location:
                        </strong>
                        <br>
                        {% if node.field_location_address.value is not empty  %}
                            {{ node.field_location_address.value }},
                        {% endif %}
                        {{ location_country_name }}
                    </div>
                </div>
                {% endif %}
                <div class="row">
                    <div class="card-icon col-1">
                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
                            width="17.626" height="17.643" viewBox="0 0 17.626 17.643">
                            <defs>
                                <clipPath id="clip-path">
                                    <rect id="Rectangle_1244" data-name="Rectangle 1244" width="17.626" height="17.643"
                                        transform="translate(0 0)" fill="none" />
                                </clipPath>
                            </defs>
                            <g id="Group_378" data-name="Group 378" transform="translate(0 0)">
                                <g id="Group_377" data-name="Group 377" clip-path="url(#clip-path)">
                                    <path id="Path_721" data-name="Path 721"
                                        d="M8.021.18a1.9,1.9,0,0,1,1.618,0l7.5,3.477a.836.836,0,0,1,0,1.515l-7.5,3.477a1.9,1.9,0,0,1-1.618,0L.482,5.172a.836.836,0,0,1,0-1.515ZM1.652,7.513,7.3,10.129a3.584,3.584,0,0,0,3.03,0l5.646-2.616,1.17.551a.835.835,0,0,1,0,1.514l-7.5,3.477a1.9,1.9,0,0,1-1.618,0L.482,9.578a.835.835,0,0,1,0-1.514ZM.482,12.47l1.17-.551L7.3,14.535a3.584,3.584,0,0,0,3.03,0l5.646-2.616,1.17.551a.836.836,0,0,1,0,1.515L9.6,17.462a1.9,1.9,0,0,1-1.618,0l-7.5-3.477a.836.836,0,0,1,0-1.515"
                                        fill="#033c6b" />
                                </g>
                            </g>
                        </svg>
                    </div>
                    <div class="col-11">
                        <strong>
                            Level of Training:
                        </strong>
                        <br>
                        {% for item in node.field_level_of_training %}
                            {{ item.entity.label }}{% if not loop.last %}, {% endif %}
                        {% endfor %}
                    </div>
                </div>
                {% if node.field_target_audience is not empty %}
                <div class="row">
                    <div class="card-icon col-1">
                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
                            width="15.423" height="18.125" viewBox="0 0 15.423 18.125">
                            <defs>
                                <clipPath id="clip-path">
                                    <rect id="Rectangle_1245" data-name="Rectangle 1245" width="15.423" height="18.125"
                                        transform="translate(0 0)" fill="none" />
                                </clipPath>
                            </defs>
                            <g id="Group_380" data-name="Group 380" transform="translate(0 0)">
                                <g id="Group_379" data-name="Group 379" clip-path="url(#clip-path)">
                                    <path id="Path_722" data-name="Path 722"
                                        d="M14.769,1.36a.81.81,0,0,1,.654.792.878.878,0,0,1-.654.826l-2.651.516V5.457a4.407,4.407,0,0,1-8.813,0V3.494L1.653,3.15V5.457L2.2,8.176v.1a.47.47,0,0,1-.482.481H.517A.5.5,0,0,1,0,8.28v-.1L.551,5.457V2.944A.9.9,0,0,1,0,2.152.811.811,0,0,1,.654,1.36L7.126.052A3.338,3.338,0,0,1,8.3.052ZM4.923,11.619,6.885,13.1v5.026h-5.3A1.014,1.014,0,0,1,.551,17.092a6.147,6.147,0,0,1,3.58-5.577.83.83,0,0,1,.792.1m5.543-6.162H4.957a2.754,2.754,0,0,0,5.509,0M8.538,13.1l1.962-1.48a.83.83,0,0,1,.792-.1,6.147,6.147,0,0,1,3.58,5.577,1.014,1.014,0,0,1-1.033,1.033h-5.3Z"
                                        fill="#033c6b" />
                                </g>
                            </g>
                        </svg>
                    </div>
                    <div class="col-11">
                        <strong>
                            Who is this training for?
                        </strong>
                        <br>
                        {% for item in node.field_target_audience %}
                            {{ item.entity.label }}{% if not loop.last %}, {% endif %}
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
                {% if content.field_registrations_date_time['#items'].0.end_date is not empty%}
                <div class="row">
                    <div class="card-icon col-1">
                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
                            width="15.423" height="16.524" viewBox="0 0 15.423 16.524">
                            <defs>
                                <clipPath id="clip-path">
                                    <rect id="Rectangle_1246" data-name="Rectangle 1246" width="15.423" height="16.524"
                                        transform="translate(0 0)" fill="none" />
                                </clipPath>
                            </defs>
                            <g id="Group_382" data-name="Group 382" transform="translate(0 0)">
                                <g id="Group_381" data-name="Group 381" clip-path="url(#clip-path)">
                                    <path id="Path_723" data-name="Path 723"
                                        d="M11.017,0a1.088,1.088,0,0,1,1.1,1.1V2.2h1.1a2.219,2.219,0,0,1,2.2,2.2v9.914a2.218,2.218,0,0,1-2.2,2.2H2.2a2.219,2.219,0,0,1-2.2-2.2V4.407A2.22,2.22,0,0,1,2.2,2.2h1.1V1.1a1.1,1.1,0,1,1,2.2,0V2.2H9.915V1.1a1.088,1.088,0,0,1,1.1-1.1m.757,5.577a.784.784,0,0,0-1.136.172L6.507,11.4,4.716,9.6a.827.827,0,0,0-1.17,1.17l2.479,2.479a.786.786,0,0,0,.654.241.71.71,0,0,0,.585-.345l4.682-6.437a.792.792,0,0,0-.172-1.136"
                                        fill="#033c6b" />
                                </g>
                            </g>
                        </svg>
                    </div>
                    <div class="col-11">
                        <strong>
                            Application/Registration Deadline:
                        </strong>
                        <br>
                        {{ content.field_registrations_date_time['#items'].0.end_date|date('F j, Y') }}
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
